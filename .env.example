# Copy this file to `.env` and update values for your tenant/workspaces.
# `scripts/deploy.py` reads these values as workspace names per environment.
#
# Resolution order used by deploy.py:
# 1) --workspace_name CLI argument
# 2) PBI_WORKSPACE_<ENV> from .env
# 3) PBI_WORKSPACE_<ENV> from scripts/deploy.config

# Development workspace name (used with --environment DEV)
PBI_WORKSPACE_DEV=Workshop - Lab 2

# Production workspace name (used with --environment PRD)
PBI_WORKSPACE_PRD=Workshop - Production
